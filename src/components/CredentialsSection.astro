---
// src/components/CredentialsSection.astro
import { getCollection } from 'astro:content';
import Card from './Card.astro';

const entries = await getCollection('credentials');
entries.sort((a, b) => (b.data.date ?? '').localeCompare(a.data.date ?? ''));
---
<section class="credentials container" id="credentials">
  <p class="section-label">education & credentials</p>
  {entries.length > 0 ? (
    <div class="grid">
      {entries.map((entry) => (
        <Card
          tag={entry.data.category}
          title={entry.data.title}
          subtitle={entry.data.date ? `${entry.data.issuer} · ${entry.data.date}` : entry.data.issuer}
          description={entry.data.description}
          link={entry.data.url}
          linkLabel="Verify ↗"
        />
      ))}
    </div>
  ) : (
    <div class="empty">
      <p>Certifications will appear here as they're earned.</p>
    </div>
  )}
</section>

<style>
  .credentials {
    padding: var(--space-lg) var(--space-md);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-sm);
  }

  .empty {
    border: 1px dashed rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    text-align: center;
  }

  p { font-size: 14px; color: var(--color-muted); }
</style>
